# PostgreSQL — ticket portal database (app.py, db_init.py)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=change_me
DB_NAME=ticket_portal

MAIL_USER=your-address@zohomail.in
MAIL_PASSWORD=your_smtp_app_password
MAIL_FROM=your-address@zohomail.in
MAIL_FROM_NAME=PerfectDesk 360
MAIL_SMTP_HOST=smtp.zoho.in
MAIL_SMTP_PORT=587

# --- Mail-to-ticket (IMAP worker: python mail_to_ticket.py) ---
# Monitors an inbox, matches ticket IDs in subject/References (portal numbering rules),
# creates tickets or appends customer replies, dedupes by Message-ID, moves to folders.
MAIL_TO_TICKET_ENABLED=1
# When 1, ``python app.py`` also starts the IMAP poller in a background thread. Set 0 if you run ``python mail_to_ticket.py`` separately.
MAIL_TO_TICKET_START_WITH_APP=1
MAIL_IMAP_HOST=imap.zoho.in
MAIL_IMAP_PORT=993
# Defaults to MAIL_USER / MAIL_PASSWORD if unset
MAIL_IMAP_USER=
MAIL_IMAP_PASSWORD=
MAIL_IMAP_MAILBOX=INBOX
MAIL_IMAP_FOLDER_PROCESSED=PortalProcessed
MAIL_IMAP_FOLDER_FAILED=PortalFailed
# Zoho often uses INBOX.Subfolder; the worker tries INBOX.{name} automatically. Extra paths (comma-separated) optional.
MAIL_IMAP_FOLDER_ALT_PATHS=
# If 1, delete from inbox when COPY/MOVE/APPEND all fail (stops UNSEEN loops; use only if you accept losing that copy).
MAIL_TO_TICKET_PURGE_ON_MOVE_FAIL=0
MAIL_TO_TICKET_POLL_INTERVAL=60
MAIL_TO_TICKET_MAX_BYTES=25165824
# Optional: comma-separated domains (no @). If empty, any sender may open a NEW ticket by mail.
MAIL_TO_TICKET_DOMAIN_ALLOWLIST=
# Public site URL for email links (same idea as PORTAL_PUBLIC_URL for the Flask app)
PORTAL_PUBLIC_URL=https://helpdesk.example.com

# Local Active Directory — auto-unlock; password reset when user selects Local (optional).
# The customer submits their chosen new password over HTTPS; the portal applies it via LDAP (not stored in the ticket).
# Password reset requires encrypted LDAP: set AD_USE_SSL=true (LDAPS) or AD_START_TLS=true on port 389.
# Do not commit real passwords. Copy to .env on the server only.
AD_LDAP_HOST=10.10.10.10
AD_LDAP_PORT=389
AD_USE_SSL=false
AD_START_TLS=false
AD_SEARCH_BASE=DC=perfectclt,DC=com
AD_BIND_USER=service.account@perfectclt.com
AD_BIND_PASSWORD=
